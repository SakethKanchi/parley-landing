---
import { meeting } from '../data/demo.js';
import Frame from './Frame.astro';
const { server, channel, title, cast, notes } = meeting;
---
<section id="demo" class="relative mx-auto max-w-6xl px-5 py-24 sm:py-28">
  <div class="mb-12 max-w-2xl" data-reveal>
    <span class="label text-primary">// 01 — Demo</span>
    <h2 class="mt-3 font-display text-[clamp(2rem,4.4vw,3rem)] font-extrabold leading-tight">See it in action</h2>
    <p class="mt-4 text-muted">Scroll to run a live meeting — Parley transcribes each speaker, then writes the notes.</p>
  </div>

  <div data-demo-pin>
    <Frame label={`${server} // #${channel}`} class="overflow-hidden shadow-2xl shadow-black/40">
      <span slot="status" data-rec-badge class="inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-widest text-accent">
        <span class="live-dot"></span> Rec
      </span>

      <div data-demo class="grid md:grid-cols-[230px_1fr]">
        <!-- voice channel rail -->
        <aside class="border-b border-edge p-4 md:border-b-0 md:border-r">
          <div class="label mb-3 flex items-center gap-2">
            <span class="live-dot"></span> Voice — {title}
          </div>
          <ul class="space-y-1.5">
            {cast.map((m) => (
              <li data-speaker={m.handle} class="flex items-center gap-3 px-2 py-2 transition-colors">
                <span class="grid h-9 w-9 place-items-center rounded-full font-mono text-xs font-bold text-white" style={`background:${m.color}`}>{m.initials}</span>
                <span class="min-w-0 flex-1">
                  <span class="block truncate text-sm text-ink">{m.handle}</span>
                  <span class="block font-mono text-[11px] uppercase tracking-wider text-muted">{m.role}</span>
                </span>
                <span data-speaking-ring={m.handle} class="h-1.5 w-1.5 shrink-0 rounded-full bg-accent opacity-0"></span>
              </li>
            ))}
          </ul>
          <div class="mt-4 hidden items-center gap-2 border-t border-edge pt-4 md:flex">
            <span class="label">Scroll to play</span>
            <span class="text-muted" aria-hidden="true">↓</span>
          </div>
        </aside>

        <!-- stage: transcript layer + notes layer (JS stacks them on desktop) -->
        <div data-stage class="relative">
          <!-- transcript -->
          <div data-stage-transcript class="border-b border-edge p-5 md:border-b-0 md:p-6">
            <div class="label mb-4 flex items-center gap-2">
              <span class="live-dot"></span> Live transcript
            </div>
            <div class="space-y-3">
              {meeting.beats.map((b, i) => {
                const m = cast.find((c) => c.handle === b.handle);
                return (
                  <div data-beat={i} class="flex items-start gap-3 opacity-0">
                    <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center rounded-full font-mono text-[10px] font-bold text-white" style={`background:${m?.color}`}>{m?.initials}</span>
                    <div class="min-w-0">
                      <span class="font-mono text-xs font-semibold text-ink">{b.handle}</span>
                      <p class="mt-0.5 text-sm leading-relaxed text-muted">{b.text}</p>
                    </div>
                  </div>
                );
              })}
            </div>
            <div data-meeting-ended class="mt-5 flex items-center justify-center gap-2 border border-accent/30 bg-accent/[0.06] px-4 py-2.5 opacity-0">
              <span class="font-mono text-[11px] uppercase tracking-widest text-accent">Meeting ended — generating notes</span>
            </div>
          </div>

          <!-- notes -->
          <div data-stage-notes class="bg-bg/40">
            <div data-notes-scroll class="p-5 md:p-6">
              <div class="mb-5 flex items-center gap-2">
                <span class="grid h-8 w-8 place-items-center rounded-full bg-primary font-mono text-[11px] font-bold text-white">P</span>
                <div class="flex items-center gap-2">
                  <span class="font-mono text-sm font-semibold text-ink">Parley</span>
                  <span class="bg-primary/20 px-1.5 py-0.5 font-mono text-[10px] text-primary">BOT</span>
                  <span class="font-mono text-xs text-muted">posted meeting notes</span>
                </div>
              </div>

              <div class="space-y-5">
                <div data-note-block>
                  <h3 class="label">TL;DR</h3>
                  <p class="mt-2 text-sm leading-relaxed text-ink">{notes.tldr}</p>
                </div>

                <div data-note-block>
                  <h3 class="label">Decisions</h3>
                  <ul class="mt-2 space-y-1.5">
                    {notes.decisions.map((d) => (
                      <li class="flex items-start gap-2 text-sm text-ink"><span class="mt-0.5 text-accent">▸</span><span>{d}</span></li>
                    ))}
                  </ul>
                </div>

                <div data-note-block>
                  <h3 class="label">Action items</h3>
                  <div class="mt-3 grid gap-3 sm:grid-cols-2">
                    {notes.actionItems.map((g) => {
                      const m = cast.find((c) => c.handle === g.handle);
                      return (
                        <div class="border border-edge bg-bg/50 p-3">
                          <div class="mb-2 flex items-center gap-2">
                            <span class="grid h-6 w-6 place-items-center rounded-full font-mono text-[10px] font-bold text-white" style={`background:${m?.color}`}>{m?.initials}</span>
                            <span class="font-mono text-sm font-medium text-ink">{g.handle}</span>
                          </div>
                          <ul class="space-y-1">
                            {g.tasks.map((t) => (
                              <li class="flex items-start gap-2 text-sm text-muted"><span class="mt-0.5 text-primary">☐</span><span>{t}</span></li>
                            ))}
                          </ul>
                        </div>
                      );
                    })}
                  </div>
                </div>

                <div data-note-block>
                  <h3 class="label">Talk-time</h3>
                  <div class="mt-3 space-y-2">
                    {notes.talkTime.map((t) => {
                      const m = cast.find((c) => c.handle === t.handle);
                      return (
                        <div class="flex items-center gap-3">
                          <span class="w-24 shrink-0 truncate font-mono text-xs text-muted">{t.handle}</span>
                          <span class="h-2.5 flex-1 overflow-hidden rounded-full bg-bg">
                            <span data-bar style={`width:${t.pct}%;background:${m?.color}`} class="block h-full origin-left rounded-full"></span>
                          </span>
                          <span class="w-8 text-right font-mono text-xs tabular-nums text-muted">{t.pct}%</span>
                        </div>
                      );
                    })}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Frame>
  </div>
</section>
