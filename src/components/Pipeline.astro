---
const steps = [
  { k: '01', t: 'Capture', d: 'Per-user PCM audio is captured from the voice channel — one isolated track per speaker.' },
  { k: '02', t: 'Transcribe', d: 'Each track is fed to the warm faster-whisper sidecar running locally on your machine.' },
  { k: '03', t: 'Summarize', d: 'The merged, speaker-labeled transcript goes to your chosen LLM — Gemini, Ollama, or OpenAI-compatible.' },
  { k: '04', t: 'Deliver', d: 'Structured notes are posted to a Discord thread. Audio is deleted after transcription.' },
];
---
<section id="how" class="relative mx-auto max-w-6xl px-5 py-24 sm:py-28">
  <div class="mb-16 max-w-2xl" data-reveal>
    <span class="label text-primary">// 04 — Pipeline</span>
    <h2 class="mt-3 font-display text-[clamp(2rem,4.4vw,3rem)] font-extrabold leading-tight">How it works</h2>
    <p class="mt-4 text-muted">Two processes on your hardware. Audio never leaves the box.</p>
  </div>

  <!-- Desktop: horizontal rail behind solid nodes -->
  <div class="relative hidden md:block" data-pipeline>
    <!-- baseline rail (sits behind nodes) -->
    <div class="absolute left-0 right-0 top-7 z-0 h-px bg-edge" aria-hidden="true"></div>
    <div data-rail class="absolute left-0 top-7 z-0 h-px bg-primary" style="width:0" aria-hidden="true"></div>

    <ol class="relative grid grid-cols-4 gap-6">
      {steps.map((s, i) => (
        <li data-reveal data-pipeline-step={i} class="group relative">
          <div class="relative z-10 mb-6 inline-grid h-14 w-14 place-items-center border border-edge bg-panel font-mono text-lg font-bold text-primary transition-colors duration-300 group-hover:border-primary">
            {s.k}
            <span class="tick tick-tl"></span>
            <span class="tick tick-br"></span>
          </div>
          <h3 class="font-display text-lg font-bold text-ink">{s.t}</h3>
          <p class="mt-2 max-w-[230px] text-sm leading-relaxed text-muted">{s.d}</p>
        </li>
      ))}
    </ol>
  </div>

  <!-- Mobile: vertical timeline -->
  <div class="relative md:hidden" data-pipeline-mobile>
    <div class="absolute left-[1.625rem] top-2 bottom-2 w-px bg-edge" aria-hidden="true">
      <div data-draw-vertical class="h-0 w-full bg-primary transition-all duration-1000"></div>
    </div>
    <ol class="relative space-y-9">
      {steps.map((s) => (
        <li data-reveal class="flex items-start gap-5">
          <div class="relative z-10 grid h-14 w-14 shrink-0 place-items-center border border-edge bg-panel font-mono text-base font-bold text-primary">
            {s.k}
            <span class="tick tick-tl"></span>
            <span class="tick tick-br"></span>
          </div>
          <div class="pt-1.5">
            <h3 class="font-display text-lg font-bold text-ink">{s.t}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-muted">{s.d}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
