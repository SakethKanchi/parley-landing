---
import Logo from './Logo.astro';
const repo = 'https://github.com/SakethKanchi/parley';
const botRepo = 'https://github.com/SakethKanchi/Discord_Meeting_Bot';

const product = [
  { href: '#demo', label: 'Demo' },
  { href: '#features', label: 'Features' },
  { href: '#how', label: 'Pipeline' },
  { href: '#quickstart', label: 'Quickstart' },
];
const resources = [
  { href: botRepo, label: 'Bot repo' },
  { href: `${botRepo}#readme`, label: 'README' },
  { href: `${botRepo}/blob/master/LICENSE`, label: 'ISC License' },
  { href: repo, label: 'Site source' },
];
---
<footer class="relative mt-8 border-t border-edge">
  <!-- CTA band -->
  <div class="mx-auto max-w-6xl px-5 py-16">
    <div class="relative grid items-center gap-8 border border-edge bg-panel/40 p-8 sm:p-12 md:grid-cols-[1fr_auto]" data-reveal>
      <span class="tick tick-tl"></span>
      <span class="tick tick-tr"></span>
      <span class="tick tick-bl"></span>
      <span class="tick tick-br"></span>
      <div>
        <span class="label text-primary">// Deploy</span>
        <h2 class="mt-3 select-none font-display text-[clamp(1.8rem,3.6vw,2.6rem)] font-extrabold leading-tight">
          Run Parley on your own box.
        </h2>
        <p class="mt-3 text-muted">Clone, drop in a token, and your Discord meetings write their own notes. No SaaS, no audio leaving your machine.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="#quickstart" class="inline-flex items-center gap-2 border border-primary bg-primary px-6 py-3 font-mono text-sm font-medium uppercase tracking-wider text-white transition-all hover:bg-transparent hover:text-primary">Quickstart →</a>
        <a href={repo} class="inline-flex items-center gap-2 border border-edge px-6 py-3 font-mono text-sm uppercase tracking-wider text-ink transition-colors hover:border-muted">★ Star</a>
      </div>
    </div>
  </div>

  <!-- link columns -->
  <div class="border-t border-edge">
    <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 sm:grid-cols-2 md:grid-cols-[1.6fr_1fr_1fr]">
      <div>
        <a href="#main" class="inline-flex items-center" aria-label="Parley home"><Logo size={26} withWordmark /></a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-muted">Self-hosted Discord meeting notes. Per-speaker transcription on your hardware, structured AI notes in a thread.</p>
        <div class="mt-5 inline-flex items-center gap-2 border border-edge px-3 py-1.5">
          <span class="live-dot"></span>
          <span class="label">Free · Open source · ISC</span>
        </div>
      </div>

      <nav aria-label="Product">
        <p class="label mb-4">Product</p>
        <ul class="space-y-2.5">
          {product.map((l) => (
            <li><a href={l.href} class="font-mono text-sm text-muted transition-colors hover:text-ink">{l.label}</a></li>
          ))}
        </ul>
      </nav>

      <nav aria-label="Resources">
        <p class="label mb-4">Resources</p>
        <ul class="space-y-2.5">
          {resources.map((l) => (
            <li><a href={l.href} class="font-mono text-sm text-muted transition-colors hover:text-ink">{l.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </div>

  <!-- meta bar -->
  <div class="border-t border-edge">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-5 py-5 font-mono text-xs text-muted sm:flex-row">
      <p>© 2026 Saketh Kanchi · ISC License</p>
      <p class="uppercase tracking-wider">Built with Astro · self-hosted on GitHub Pages</p>
    </div>
  </div>
</footer>
