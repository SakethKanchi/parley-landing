---
import { features } from '../data/features.js';
import FeatureCard from './FeatureCard.astro';
---
<section id="features" class="relative overflow-hidden border-y border-edge bg-bg-elevated">
  <div class="mx-auto max-w-6xl px-5 py-24 sm:py-28">
    <div class="mb-14 max-w-2xl" data-reveal>
      <span class="label text-primary">// 02 — Features</span>
      <h2 class="mt-3 font-display text-[clamp(2rem,4.4vw,3rem)] font-extrabold leading-tight">Everything a meeting bot should be</h2>
      <p class="mt-4 text-muted">Built for self-hosting, privacy, and the way Discord actually works.</p>
    </div>

    <div data-feature-grid class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {features.map((f, i) => <FeatureCard title={f.title} body={f.body} icon={f.icon} index={i} />)}
    </div>
  </div>
</section>
