---
import Logo from './Logo.astro';
const repo = 'https://github.com/SakethKanchi/parley';
const links = [
  { href: '#demo', label: 'Demo' },
  { href: '#dashboard', label: 'Dashboard' },
  { href: '#features', label: 'Features' },
  { href: '#how', label: 'Pipeline' },
  { href: '#quickstart', label: 'Quickstart' },
];

const themes = [
  { id: 'parley', label: 'Parley' },
  { id: 'catppuccin', label: 'Catppuccin' },
  { id: 'rose-pine', label: 'Rose Pine' },
  { id: 'kanagawa', label: 'Kanagawa' },
  { id: 'tokyo-night', label: 'Tokyo Night' },
];
---
<header
  id="nav"
  class="fixed inset-x-0 top-0 z-40 border-b border-transparent transition-colors duration-300"
  data-nav
>
  <nav aria-label="Main" class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3.5">
    <a href="#main" class="flex items-center gap-2.5" aria-label="Parley home">
      <Logo size={26} withWordmark />
    </a>

    <!-- Desktop links -->
    <div class="hidden items-center gap-7 md:flex">
      {links.map((l) => (
        <a href={l.href} class="nav-link font-mono text-xs uppercase tracking-widest text-muted transition-colors hover:text-ink">{l.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-2.5">
      <!-- Theme picker (desktop) -->
      <div class="relative hidden md:block">
        <select
          data-theme-select
          aria-label="Color theme"
          class="appearance-none rounded-none border border-edge bg-panel px-3 py-2 pr-8 font-mono text-xs uppercase tracking-wider text-muted outline-none transition-colors hover:text-ink focus:border-primary"
        >
          {themes.map((t) => (
            <option value={t.id}>{t.label}</option>
          ))}
        </select>
        <svg class="pointer-events-none absolute right-2 top-1/2 h-3 w-3 -translate-y-1/2 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 9l6 6 6-6" />
        </svg>
      </div>

      <a
        href={repo}
        class="group relative inline-flex items-center gap-2 border border-primary bg-primary px-4 py-2 font-mono text-xs font-medium uppercase tracking-wider text-white transition-all hover:bg-transparent hover:text-primary"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.6 7.1.6-5.4 4.7 1.6 7L12 17.8 5.8 21l1.6-7L2 9.2l7.1-.6z"/></svg>
        Star
      </a>

      <!-- Mobile menu toggle -->
      <button
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="relative h-9 w-9 border border-edge bg-panel md:hidden"
        data-menu-toggle
      >
        <span class="sr-only">Menu</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-ink">
          <path d="M4 7h16" />
          <path d="M4 12h16" />
          <path d="M4 17h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="hidden border-t border-edge bg-bg/95 backdrop-blur md:hidden"
    data-mobile-menu
  >
    <div class="mx-auto max-w-6xl px-5 py-4">
      <div class="flex flex-col gap-3">
        {links.map((l) => (
          <a href={l.href} class="font-mono text-sm uppercase tracking-wider text-muted transition-colors hover:text-ink">{l.label}</a>
        ))}
      </div>
      <!-- Theme picker (mobile) -->
      <div class="mt-4 border-t border-edge pt-4">
        <label class="label mb-2 block">Theme</label>
        <select
          data-theme-select-mobile
          class="w-full appearance-none rounded-none border border-edge bg-panel px-3 py-2 font-mono text-sm text-ink outline-none"
        >
          {themes.map((t) => (
            <option value={t.id}>{t.label}</option>
          ))}
        </select>
      </div>
    </div>
  </div>
</header>
<script>
  const nav = document.querySelector('[data-nav]');
  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 24) {
      nav.classList.add('border-edge', 'bg-bg/80', 'backdrop-blur');
    } else {
      nav.classList.remove('border-edge', 'bg-bg/80', 'backdrop-blur');
    }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const toggle = document.querySelector('[data-menu-toggle]');
  const menu = document.querySelector('[data-mobile-menu]');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(!open));
      toggle.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
    });
  }
</script>
