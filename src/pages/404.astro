---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found — Parley">
  <main id="main" class="grid min-h-screen place-items-center px-5">
    <div class="text-center">
      <div data-hero-logo class="mb-6 flex justify-center">
        <svg width="64" height="64" viewBox="0 0 48 48" fill="none" role="img" aria-label="Parley logo" class="parley-logo">
          <g stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round">
            <line x1="4" y1="19" x2="4" y2="29"/>
            <line x1="8" y1="15" x2="8" y2="33"/>
            <line x1="12" y1="10" x2="12" y2="38"/>
            <line x1="16" y1="13" x2="16" y2="35"/>
            <line x1="20" y1="17" x2="20" y2="31"/>
            <line x1="24" y1="20" x2="24" y2="28"/>
            <line x1="28" y1="18" x2="28" y2="30"/>
          </g>
          <line x1="30" y1="24" x2="44" y2="24" stroke="var(--color-accent)" stroke-width="3" stroke-linecap="round"/>
        </svg>
      </div>
      <h1 class="font-display text-6xl font-bold text-primary">404</h1>
      <p class="mt-4 text-lg text-muted">This page does not exist.</p>
      <a href={import.meta.env.BASE_URL} class="mt-8 inline-block rounded-xl bg-primary px-6 py-3 font-medium text-white transition-transform hover:scale-[1.03]">Back to Parley →</a>
    </div>
  </main>
</Base>
